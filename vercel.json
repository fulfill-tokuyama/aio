{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "regions": ["hnd1"],
  "crons": [
    {
      "path": "/api/rescan",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/auto-send",
      "schedule": "0 1 * * 1-5"
    },
    {
      "path": "/api/cron/brand-check",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 0 1 * *"
    }
  ]
}
